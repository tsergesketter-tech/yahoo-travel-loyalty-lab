{
  "info": {
    "name": "Yahoo Travel Loyalty Lab — Salesforce APIs",
    "description": "Direct Salesforce Loyalty Management API collection for Yahoo Rewards.\n\nSetup:\n1. Set `sf_instance_url` to your Salesforce instance (e.g. https://myorg.my.salesforce.com)\n2. Set `sf_client_id` and `sf_client_secret` from your Connected App\n3. Run 'Get Access Token' first — it auto-sets `sf_access_token`\n4. All subsequent requests use Bearer auth automatically",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "sf_instance_url", "value": "https://trailsignup-78f9c4eccfa797.my.salesforce.com", "type": "string" },
    { "key": "sf_client_id", "value": "", "type": "string" },
    { "key": "sf_client_secret", "value": "", "type": "string" },
    { "key": "sf_access_token", "value": "", "type": "string" },
    { "key": "sf_api_version", "value": "v66.0", "type": "string" },
    { "key": "loyalty_program", "value": "Yahoo Rewards", "type": "string" },
    { "key": "membership_number", "value": "YAH0000001", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{sf_access_token}}", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Get Access Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access_token) {",
                  "    pm.collectionVariables.set('sf_access_token', json.access_token);",
                  "    pm.collectionVariables.set('sf_instance_url', json.instance_url);",
                  "    console.log('Token set successfully. Instance: ' + json.instance_url);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "client_credentials" },
                { "key": "client_id", "value": "{{sf_client_id}}" },
                { "key": "client_secret", "value": "{{sf_client_secret}}" }
              ]
            },
            "url": {
              "raw": "{{sf_instance_url}}/services/oauth2/token",
              "host": ["{{sf_instance_url}}"],
              "path": ["services", "oauth2", "token"]
            },
            "description": "Authenticate via OAuth2 client_credentials flow. Auto-sets sf_access_token for all subsequent requests."
          }
        }
      ]
    },
    {
