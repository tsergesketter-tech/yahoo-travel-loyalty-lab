        {
          "name": "Query — Transaction Journals",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/loyalty/query?q=SELECT Id, TransactionJournalNumber, JournalTypeName, JournalSubTypeName, TransactionAmount, ActivityDate FROM TransactionJournal ORDER BY ActivityDate DESC LIMIT 20",
              "host": ["{{base_url}}"],
