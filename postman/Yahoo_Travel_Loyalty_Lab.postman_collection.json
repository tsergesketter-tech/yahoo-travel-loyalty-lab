              "host": ["{{sf_instance_url}}"],
              "path": ["services", "data", "{{sf_api_version}}", "loyalty-programs", "{{loyalty_program}}", "members"],
              "query": [
                { "key": "membershipNumber", "value": "{{membership_number}}" }
