              "raw": "{\n  \"cart\": {\n    \"cartDetails\": [\n      {\n        \"activityStartDate\": \"2026-05-20T00:00:00.000Z\",\n        \"membershipNumber\": \"{{membershipNumber}}\",\n        \"currencyISOCode\": \"USD\",\n        \"transactionAmount\": 1000,\n        \"origin\": \"San Francisco\",\n        \"destination\": \"New York\"\n      }\n    ]\n  }\n}"
