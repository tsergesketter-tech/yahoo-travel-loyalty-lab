    {
      "name": "SOQL Explorer",
      "item": [
        {
          "name": "Query — Active Promotions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/loyalty/query?q=SELECT Id, Name, LoyaltyPromotionType, StartDate, EndDate FROM Promotion WHERE IsActive = true",
              "host": ["{{base_url}}"],
              "path": ["api", "loyalty", "query"],
              "query": [
                {
                  "key": "q",
                  "value": "SELECT Id, Name, LoyaltyPromotionType, StartDate, EndDate FROM Promotion WHERE IsActive = true"
                }
              ]
