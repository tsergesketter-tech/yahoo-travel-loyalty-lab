          "name": "Query — Loyalty Program Members",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/loyalty/query?q=SELECT Id, MembershipNumber, MemberStatus, EnrollmentDate FROM LoyaltyProgramMember LIMIT 10",
              "host": ["{{base_url}}"],
