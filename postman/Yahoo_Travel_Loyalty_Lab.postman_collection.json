{
  "info": {
    "name": "Yahoo Travel Loyalty Lab",
    "description": "API collection for Yahoo Travel Loyalty Lab — Salesforce Loyalty Management integration.\n\nSet the `base_url` variable to your server URL (e.g. http://localhost:3002 or your Heroku app URL).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3002",
      "type": "string"
    },
    {
      "key": "membershipNumber",
      "value": "YAH0000001",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health & Setup",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/health",
              "host": ["{{base_url}}"],
              "path": ["api", "health"]
            },
            "description": "Verify the server is running and connected to the Yahoo Rewards program."
          }
        }
      ]
    },
    {
      "name": "Member Profile",
      "item": [
        {
          "name": "Get Member Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/loyalty/member-profile?membershipNumber={{membershipNumber}}",
              "host": ["{{base_url}}"],
              "path": ["api", "loyalty", "member-profile"],
              "query": [
                {
                  "key": "membershipNumber",
                  "value": "{{membershipNumber}}"
                }
              ]
            },
            "description": "Retrieve full member profile including points balances, tier, currencies, and enrollment info."
          }
        }
      ]
    },
