    {
      "name": "Promotions",
      "item": [
        {
          "name": "Get All Promotions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/loyalty/promotions?membershipNumber={{membershipNumber}}",
              "host": ["{{base_url}}"],
              "path": ["api", "loyalty", "promotions"],
